#!/usr/bin/env bash
# Render `git log --graph` with box-drawing glyphs and dimmed metadata.
#
# Lazygit drives this from branchLogCmd / allBranchesLogCmds. Those run via
# str.ToArgv (direct argv exec, NO shell — see lazygit branch.go), so a
# `git log ... | perl` pipe can't live in the config: the `|` would become a
# literal git arg. This wrapper owns the pipe instead; the config just calls it
# and forwards args ("$@" = `<branch> --` for one branch, `--all` for the rest).
#
# `git --no-pager` because lazygit sets GIT_PAGER to the diff pager (hunk),
# which strips ANSI from plain `git log` and kills the color.
#
# Why post-process in perl rather than a custom --pretty format with %C(...):
#   1. --graph redraws the gutter (and resets color) at the start of every line,
#      so a single %C(#485163) span dies after the first line — each line must be
#      re-colored, which perl does and a format span can't.
#   2. git-log formats have no conditional, so they can't emit `Merge:` only for
#      merge commits. --pretty=medium gives Merge:/Author:/Date: natively.
#
# The perl filter rewrites:
#   header:     drops the `commit ` keyword — the line only ever holds
#                 `commit <sha> [decoration]`, so the short SHA (still yellow)
#                 sits right after the node
#   gutter:     | * / \       ->  │ ● ╱ ╲   (U+2502 U+25CF U+2571 U+2572)
#                 (only the leading gutter, so / and \ in messages/refs survive)
#   merge fork: `|\` (one parent lane opening) is drawn as a rounded corner on the
#                 *node* line above — `●` becomes `●─╮` (U+2500 U+256E) and the old
#                 fork line is straightened to plain lanes (`│ │`). Needs the node
#                 line, so the filter buffers one line of lookahead.
#   collapse:   `|/` (a lane folding back in) becomes `├─╯` (U+251C U+2500 U+256F) in
#                 place — `├` marks the split point on the through-lane it folds into.
#                 Both only fire for a single rightmost diagonal (gutter ending `|\`
#                 / `|/`); other compound junctions (`|\ \`, `|/ /`) stay diagonal.
#                 One trailing gutter space is reclaimed so column width is unchanged.
#   merge:      `|\|` (a merge whose second-parent lane keeps going below the merge)
#                 draws `●─┤` (U+2500 U+2524) on the node line: the merge ties into the
#                 continuing through-lane with a left tick instead of a fresh `╮` corner,
#                 and the fork line's diagonal is straightened to `│ │`. Same shape as
#                 the `|\` fork, but for a lane that continues rather than one that opens.
#   decoration: HEAD -> main  ->  HEAD ⟶ main   (U+27F6, only when ANSI-wrapped,
#                 so a literal `->` in a commit message is left alone). Tag refs
#                 are recolored bold magenta (git color.decorate.tag override) to
#                 match lazygit's FgMagenta tags; other ref slots keep git defaults.
#   metadata:   dimmed to #485163 (theme color, truecolor 38;2;72;81;99) —
#                 `Author:` label + `<email>` dimmed; the author NAME gets the
#                 same per-name color lazygit paints in its commits panel —
#                 md5(name) -> HSL -> RGB, replicating lazygit's authors.go +
#                 go-colorful exactly (verified byte-for-byte; see acolor()).
#                 `Date:` / `Merge:` whole line dimmed. Matched only inside the
#                 header block (commit line .. blank line), so a message body
#                 starting with "Author:"/"Date:" is never touched.
git --no-pager -c color.decorate.tag='bold magenta' \
    log --graph --color=always --abbrev-commit --decorate \
    --date=relative --pretty=medium "$@" \
  | perl -CSDA -ne '
use Digest::MD5 qw(md5); use Encode qw(encode_utf8);
# acolor($name) -> "R;G;B": lazygit AuthorStyle, md5(name) -> HSL -> truecolor.
sub _chan { my ($t1,$t2,$t)=@_; return $t2+($t1-$t2)*6*$t if 6*$t<1; return $t1 if 2*$t<1; return $t2+($t1-$t2)*(2.0/3.0-$t)*6 if 3*$t<2; $t2 }
sub _hsl { my ($h,$s,$l)=@_; my ($t1,$t2); if ($l<0.5){$t1=$l*(1.0+$s)} else {$t1=$l+$s-$l*$s} $t2=2*$l-$t1; $h/=360; my $tr=$h+1/3; my $tg=$h; my $tb=$h-1/3; $tr++ if $tr<0; $tr-- if $tr>1; $tg++ if $tg<0; $tg-- if $tg>1; $tb++ if $tb<0; $tb-- if $tb>1; (_chan($t1,$t2,$tr),_chan($t1,$t2,$tg),_chan($t1,$t2,$tb)) }
sub acolor { my @b=unpack("C16",md5(encode_utf8($_[0]))); my ($r,$g,$bl)=_hsl((($b[0]+$b[1]+$b[2]+$b[3])%100)/100*360, 0.6+0.4*(($b[4]+$b[5]+$b[6]+$b[7])%100)/100, 0.4+(($b[8]+$b[9]+$b[10]+$b[11])%100)/100*0.2); sprintf("%d;%d;%d",int($r*255),int($g*255),int($bl*255)) }
my $r = $_; $r =~ s/\x1b\[[0-9;]*m//g; $r =~ /^([ |*\/\\_]*)/; my $g = $1; $g =~ s/\s+$//;
my $fork = $g =~ /\|\\$/; my $coll = $g =~ /\|\/$/; my $merge = $g =~ /\|\\\|$/;
s{^((?:\x1b\[[0-9;]*m|[ |*/\\_])+)}{ my $x=$1; $x=~s/\|/\x{2502}/g; $x=~s/\*/\x{25CF}/g; $x=~s{/}{\x{2571}}g; $x=~s/\\/\x{2572}/g; $x }ge;
s/(\x1b\[[0-9;]*m) -> (\x1b\[m)/$1 \x{27F6} $2/g;
my $gut = qr/(?:\x1b\[[0-9;]*m|[ \x{2502}\x{25CF}\x{2571}\x{2572}|*\/\\_])*/;
(my $c = $_) =~ s/\x1b\[[0-9;]*m//g;
$c =~ s/^[ \x{2502}\x{25CF}\x{2571}\x{2572}|*\/\\_]+//;
if ($c =~ /^commit [0-9a-f]{4,}/) { $H = 1; s/(\x1b\[[0-9;]*m)?commit (?=[0-9a-f]{4,})/$1/ }
elsif ($H) {
    if ($c =~ /^\s*$/) { $H = 0 }
    elsif ($c =~ /^Author:/) { s/^($gut)Author:\s+(.+?)\s+(<[^>]*>)/"$1\x1b[38;2;72;81;99mAuthor: \x1b[m\x1b[38;2;".acolor($2)."m$2\x1b[m \x1b[38;2;72;81;99m$3\x1b[m"/e }
    elsif ($c =~ /^(?:Date|Merge|Commit|AuthorDate|CommitDate|Reflog):/) { s/^($gut)(\S.*\S|\S)/$1\x1b[38;2;72;81;99m$2\x1b[m/ }
}
if ($coll) { s/(\x1b\[[0-9;]*m)?\x{2571}(\x1b\[[0-9;]*m)? /$1\x{2500}\x{256F}$2/; s/\x{2502}((?:\x1b\[[0-9;]*m)*\x{2500}\x{256F})/\x{251C}$1/ }
if ($fork) { my ($lc) = /(\x1b\[[0-9;]*m)\x{2572}/; if (defined $lc && defined $prev && $prev =~ s/(\x{25CF})  /$1${lc}\x{2500}\x{256E}\x1b[m/) { s/(\x1b\[[0-9;]*m)?\x{2572}(\x1b\[[0-9;]*m)? / $1\x{2502}$2/ } }
if ($merge) { my ($lc) = /(\x1b\[[0-9;]*m)\x{2572}/; if (defined $lc && defined $prev && $prev =~ s/(\x{25CF}) (?:\x1b\[[0-9;]*m)*\x{2502}(?:\x1b\[[0-9;]*m)*/$1${lc}\x{2500}\x{2524}\x1b[m/) { s/(?:\x1b\[[0-9;]*m)?\x{2572}(?:\x1b\[[0-9;]*m)?/ / } }
print $prev if defined $prev; $prev = $_;
END { print $prev if defined $prev }
'
