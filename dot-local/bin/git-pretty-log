#!/usr/bin/env bash
# Render `git log --graph` with box-drawing glyphs and dimmed metadata.
#
# Lazygit drives this from branchLogCmd / allBranchesLogCmds. Those run via
# str.ToArgv (direct argv exec, NO shell â€” see lazygit branch.go), so a
# `git log ... | perl` pipe can't live in the config: the `|` would become a
# literal git arg. This wrapper owns the pipe instead; the config just calls it
# and forwards args ("$@" = `<branch> --` for one branch, `--all` for the rest).
#
# `git --no-pager` because lazygit sets GIT_PAGER to the diff pager (hunk),
# which strips ANSI from plain `git log` and kills the color.
#
# Why post-process in perl rather than a custom --pretty format with %C(...):
#   1. --graph redraws the gutter (and resets color) at the start of every line,
#      so a single %C(#485163) span dies after the first line â€” each line must be
#      re-colored, which perl does and a format span can't.
#   2. git-log formats have no conditional, so they can't emit `Merge:` only for
#      merge commits. --pretty=medium gives Merge:/Author:/Date: natively.
#
# The perl filter rewrites:
#   header:     drops the `commit ` keyword â€” the line only ever holds
#                 `commit <sha> [decoration]`, so the short SHA (still yellow)
#                 sits right after the node
#   gutter:     | * / \       ->  â”‚ â—Ź â•± â•˛   (U+2502 U+25CF U+2571 U+2572)
#                 (only the leading gutter, so / and \ in messages/refs survive)
#   merge fork: `|\` (one parent lane opening) is drawn as a rounded corner on the
#                 *node* line above â€” `â—Ź` becomes `â—Źâ”€â•®` (U+2500 U+256E) and the old
#                 fork line is straightened to plain lanes (`â”‚ â”‚`). Needs the node
#                 line, so the filter buffers one line of lookahead.
#   collapse:   `|/` (a lane folding back in) becomes `â”śâ”€â•Ż` (U+251C U+2500 U+256F) in
#                 place â€” `â”ś` marks the split point on the through-lane it folds into.
#                 Both only fire for a single rightmost diagonal (gutter ending `|\`
#                 / `|/`); compound junctions (`|\|`, `|\ \`, `|/ /`) stay diagonal.
#                 One trailing gutter space is reclaimed so column width is unchanged.
#   decoration: HEAD -> main  ->  HEAD âź¶ main   (U+27F6, only when ANSI-wrapped,
#                 so a literal `->` in a commit message is left alone)
#   metadata:   dimmed to #485163 (theme color, truecolor 38;2;72;81;99) â€”
#                 `Author:` label + `<email>` dimmed, author NAME bold;
#                 `Date:` / `Merge:` whole line dimmed. Matched only inside the
#                 header block (commit line .. blank line), so a message body
#                 starting with "Author:"/"Date:" is never touched.
git --no-pager log --graph --color=always --abbrev-commit --decorate \
    --date=relative --pretty=medium "$@" \
  | perl -CSDA -ne '
my $r = $_; $r =~ s/\x1b\[[0-9;]*m//g; $r =~ /^([ |*\/\\_]*)/; my $g = $1; $g =~ s/\s+$//;
my $fork = $g =~ /\|\\$/; my $coll = $g =~ /\|\/$/;
s{^((?:\x1b\[[0-9;]*m|[ |*/\\_])+)}{ my $x=$1; $x=~s/\|/\x{2502}/g; $x=~s/\*/\x{25CF}/g; $x=~s{/}{\x{2571}}g; $x=~s/\\/\x{2572}/g; $x }ge;
s/(\x1b\[[0-9;]*m) -> (\x1b\[m)/$1 \x{27F6} $2/g;
my $gut = qr/(?:\x1b\[[0-9;]*m|[ \x{2502}\x{25CF}\x{2571}\x{2572}|*\/\\_])*/;
(my $c = $_) =~ s/\x1b\[[0-9;]*m//g;
$c =~ s/^[ \x{2502}\x{25CF}\x{2571}\x{2572}|*\/\\_]+//;
if ($c =~ /^commit [0-9a-f]{4,}/) { $H = 1; s/(\x1b\[[0-9;]*m)?commit (?=[0-9a-f]{4,})/$1/ }
elsif ($H) {
    if ($c =~ /^\s*$/) { $H = 0 }
    elsif ($c =~ /^Author:/) { s/^($gut)Author:\s+(.+?)\s+(<[^>]*>)/$1\x1b[38;2;72;81;99mAuthor: \x1b[m\x1b[1m$2\x1b[22m \x1b[38;2;72;81;99m$3\x1b[m/ }
    elsif ($c =~ /^(?:Date|Merge|Commit|AuthorDate|CommitDate|Reflog):/) { s/^($gut)(\S.*\S|\S)/$1\x1b[38;2;72;81;99m$2\x1b[m/ }
}
if ($coll) { s/(\x1b\[[0-9;]*m)?\x{2571}(\x1b\[[0-9;]*m)? /$1\x{2500}\x{256F}$2/; s/\x{2502}((?:\x1b\[[0-9;]*m)*\x{2500}\x{256F})/\x{251C}$1/ }
if ($fork) { my ($lc) = /(\x1b\[[0-9;]*m)\x{2572}/; if (defined $lc && defined $prev && $prev =~ s/(\x{25CF})  /$1${lc}\x{2500}\x{256E}\x1b[m/) { s/(\x1b\[[0-9;]*m)?\x{2572}(\x1b\[[0-9;]*m)? / $1\x{2502}$2/ } }
print $prev if defined $prev; $prev = $_;
END { print $prev if defined $prev }
'
