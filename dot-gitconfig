[user]
	name = François Best
	email = github@francoisbest.com
[core]
	excludesfile = ~/.gitignore_global
[color]
	ui = auto
[init]
	defaultBranch = main
[rerere]
	enabled = true
[remote "origin"]
	prune = true
[push]
	default = current
[alias]
	dlog = "!f() { git log -p \"$@\" | hunk pager; }; f"
	dshow = "!hunk show"
