[user]
	name = François Best
	email = github@francoisbest.com
[core]
	excludesfile = ~/.gitignore_global
[color]
	ui = auto
[init]
	defaultBranch = main
[rerere]
	enabled = true
[diff]
	external = difft --display=inline
[remote "origin"]
	prune = true
[push]
	default = current
[alias]
	dlog = -c diff.external=difft log -p --ext-diff
	dshow = -c diff.external=difft show --ext-diff
