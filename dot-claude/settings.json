{
  "env": {
    "ENABLE_EXPERIMENTAL_MCP_CLI": "true"
  },
  "permissions": {
    "allow": [
      "Bash(git bisect *)",
      "Bash(git blame *)",
      "Bash(git branch *)",
      "Bash(git checkout *)",
      "Bash(git cherry-pick *)",
      "Bash(git clean *)",
      "Bash(git clone *)",
      "Bash(git config *)",
      "Bash(git describe *)",
      "Bash(git diff-tree *)",
      "Bash(git diff *)",
      "Bash(git fetch *)",
      "Bash(git for-each-ref *)",
      "Bash(git init *)",
      "Bash(git log *)",
      "Bash(git ls-files *)",
      "Bash(git ls-tree *)",
      "Bash(git merge *)",
      "Bash(git mkdir*)",
      "Bash(git mv *)",
      "Bash(git name-rev *)",
      "Bash(git pull *)",
      "Bash(git rebase *)",
      "Bash(git reflog *)",
      "Bash(git reset *)",
      "Bash(git restore *)",
      "Bash(git rev-list *)",
      "Bash(git rev-parse *)",
      "Bash(git rm *)",
      "Bash(git shortlog *)",
      "Bash(git show *)",
      "Bash(git stash *)",
      "Bash(git status *)",
      "Bash(git switch *)",
      "Bash(git symbolic-ref *)",
      "Bash(git tag *)",
      "Bash(git worktree *)",
      "Bash(awk *)",
      "Bash(basename *)",
      "Bash(cat *)",
      "Bash(cut *)",
      "Bash(diff *)",
      "Bash(dirname *)",
      "Bash(echo *)",
      "Bash(file *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(head *)",
      "Bash(jq *)",
      "Bash(ls *)",
      "Bash(lsof *)",
      "Bash(mkdir *)",
      "Bash(pwd)",
      "Bash(readlink *)",
      "Bash(sed *)",
      "Bash(sort *)",
      "Bash(stat *)",
      "Bash(tail *)",
      "Bash(tr *)",
      "Bash(tree *)",
      "Bash(type *)",
      "Bash(uniq *)",
      "Bash(wc *)",
      "Bash(which *)",
      "Bash(xargs cat*)",
      "Bash(node --version*)",
      "Bash(npm --version*)",
      "Bash(npm info *)",
      "Bash(npm view *)",
      "Bash(pnpm --version*)",
      "Bash(bun --version*)",
      "Bash(pnpm list *)",
      "Bash(pnpm why *)",
      "Bash(pnpm test*)",
      "Bash(pnpm build*)",
      "Bash(pnpm lint*)",
      "Bash(pnpm run*)",
      "Bash(bun test*)",
      "Bash(bun build*)",
      "Bash(bun lint*)",
      "Bash(bun run*)",
      "Bash(bun --version *)",
      "Bash(gh --version *)",
      "Bash(gh api *)",
      "Bash(gh issue list *)",
      "Bash(gh issue view *)",
      "Bash(gh label list *)",
      "Bash(gh pr checks *)",
      "Bash(gh pr diff *)",
      "Bash(gh pr list *)",
      "Bash(gh pr view *)",
      "Bash(gh repo view *)",
      "Bash(gh search *)",
      "WebFetch",
      "WebSearch",
      "mcp__context7__get-library-docs",
      "mcp__context7__resolve-library-id",
      "mcp__shadcn__view_items_in_registries",
      "mcp__shadcn__get_add_command_for_items",
      "mcp__shadcn__get_item_examples_from_registries"
    ],
    "deny": [
      "Bash(sudo *)",
      "Bash(dd *)",
      "Bash(mkfs *)",
      "Bash(curl * | bash *)",
      "Bash(curl * | sh *)",
      "Bash(curl * | zsh *)",
      "Bash(wget * | bash *)",
      "Bash(wget * | sh *)",
      "Bash(wget * | zsh *)",
      "Bash(git push *)",
      "Bash(npm *)",
      "Bash(yarn *)",
      "Read(.env*)",
      "Edit(.env*)"
    ],
    "ask": ["Bash(pnpm add *)", "Bash(bun add *)", "Bash(gh pr create *)"],
    "defaultMode": "bypassPermissions"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/block-dangerous-git.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/check-rm-git-tracked.sh",
            "if": "Bash(rm *)"
          }
        ]
      }
    ],
    "WorktreeCreate": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/worktree-create.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "code-review@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "swift-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "caveman@caveman": true
  },
  "extraKnownMarketplaces": {
    "caveman": {
      "source": {
        "source": "github",
        "repo": "JuliusBrussee/caveman"
      }
    }
  },
  "spinnerVerbs": {
    "mode": "replace",
    "verbs": ["Processing"]
  },
  "effortLevel": "high",
  "skipDangerousModePermissionPrompt": true,
  "agentPushNotifEnabled": true
}
